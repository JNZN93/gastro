{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/gastro-kom/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://multi-mandant-ecommerce.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
